# Copiar este arquivo para .env e preencher os valores antes de iniciar em producao.
# Uso: set SECRET_KEY=... (Windows) ou export SECRET_KEY=... (Linux)

# ── Obrigatorio em producao ──────────────────────────────────────
# Gere uma chave com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# ── Servidor ─────────────────────────────────────────────────────
PORT=5000

# ── Email (opcional) ─────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Assistente IA / OpenRouter (opcional) ─────────────────────────
# Gere uma chave em https://openrouter.ai/keys
AI_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=tencent/hy3:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
